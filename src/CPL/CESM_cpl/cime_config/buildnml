def buildnml(case, caseroot, compname):
    """Build the wrfhydro control file """

    # cp the namelist file
    if compname != "wrfhydro":
        raise AttributeError

    src_root = case.get_value("COMP_ROOT_DIR_ROF")
    run_dir = case.get_value("RUNDIR")

    nml_template = "hydro.namelist.template"
    nml_src = os.path.join(src_root+'/cime_config', nml_template)

    nml_file = "hydro.namelist"
    nml_destination = os.path.join(run_dir, nml_file)

    print(f"   - copying namelist {nml_template} to {nml_destination}")
    shutil.copy(nml_src, nml_destination)

    tarball_url = "https://github.com/NCAR/wrf-hydro_cesm/releases/download/0.0.1/ctsm_100m_routing_stack.tar.gz"
    download_and_extract_tarball(tarball_url, run_dir)

def download_and_extract_tarball(tarball_url, run_dir):
    """
    Download a tar.gz file, extract it, and move its contents to run_dir/DOMAIN.
    """

    run_dir = Path(run_dir)
    domain_dir = run_dir / "DOMAIN"
    tarball = run_dir / Path(tarball_url).name
    extract_tmp = run_dir / "_tarball_extract_tmp"

    run_dir.mkdir(parents=True, exist_ok=True)

    # Download
    urllib.request.urlretrieve(tarball_url, tarball)

    # Clean old temporary extract directory
    if extract_tmp.exists():
        shutil.rmtree(extract_tmp)
    extract_tmp.mkdir(parents=True)

    # Extract
    with tarfile.open(tarball, "r:gz") as tf:
        tf.extractall(extract_tmp)

    # Replace run_dir/DOMAIN
    if domain_dir.exists():
        shutil.rmtree(domain_dir)

    # If the tarball contains one top-level directory, move it to DOMAIN.
    # Otherwise, put all extracted contents inside DOMAIN.
    items = list(extract_tmp.iterdir())
    if len(items) == 1 and items[0].is_dir():
        shutil.move(str(items[0]), str(domain_dir))
    else:
        domain_dir.mkdir(parents=True)
        for item in items:
            shutil.move(str(item), str(domain_dir / item.name))

    # Cleanup
    tarball.unlink()
    shutil.rmtree(extract_tmp)

    return domain_dir

def _main_func():
    caseroot = parse_input(sys.argv)
    with Case(case_root=caseroot) as case:
        buildnml(case, caseroot, "wrfhydro")

if __name__ == "__main__":
    _main_func()
